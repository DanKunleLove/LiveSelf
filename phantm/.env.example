# ============================================
# LiveSelf Environment Variables
# Copy this to .env and fill in your values
# ============================================

# --- Image Generation (project assets, not user-facing) ---
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO_API_KEY=

# --- Phase 1: Engine (AI Pipeline) ---

# Ollama (local LLM - no key needed if running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Claude API (premium LLM - optional, for Phase 2+)
# Get from: https://console.anthropic.com
# Cost: ~$0.003 per avatar response
ANTHROPIC_API_KEY=

# --- Phase 2: Backend ---

# Supabase (Database + Auth)
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (File Storage - photos, voice samples)
# Get from: https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=liveself-assets

# Redis (Caching - Upstash free tier)
# Get from: https://upstash.com
REDIS_URL=

# Internal API key for engine <-> backend communication
# Generate: openssl rand -hex 32
ENGINE_API_KEY=

# --- Phase 3: Payments & Services ---

# Stripe (Billing)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (Email)
# Get from: https://resend.com
RESEND_API_KEY=

# --- App Config ---
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENGINE_URL=http://localhost:8001

# JWT Secret (for auth tokens)
# Generate: openssl rand -hex 64
JWT_SECRET=
